package model

import (
	"fmt"
	"sort"
	"strings"

	"github.com/StxrlessLabs/webber/choices"
	"github.com/charmbracelet/bubbles/textinput"
	tea "github.com/charmbracelet/bubbletea"
)

type PageModel struct {
	Page        *choices.SubCategory
	keys        []string
	cursor      int
	selected    map[int]struct{}
	ti          textinput.Model
	inputActive bool
}

func NewPageModel(page *choices.SubCategory) *PageModel {
	ti := textinput.New()
	ti.Placeholder = "enter value..."
	keys := make([]string, 0, len(page.Commands))
	for k := range page.Commands {
		keys = append(keys, k)
	}
	sort.Strings(keys)

	return &PageModel{
		Page:     page,
		keys:     keys,
		selected: make(map[int]struct{}),
		ti:       ti,
	}
}

func (m *PageModel) CursorUp() {
	if m.cursor > 0 {
		m.cursor--
	}
}

func (m *PageModel) CursorDown() {
	if m.cursor < len(m.keys)-1 {
		m.cursor++
	}
}

func (m *PageModel) ToggleSelected() (needsInput bool) {
	if len(m.keys) == 0 {
		return
	}

	if !m.Page.IsMultiChoice {
		_, already := m.selected[m.cursor]
		m.selected = make(map[int]struct{})
		if !already {
			m.selected[m.cursor] = struct{}{}
		}
		return
	}

	if _, ok := m.selected[m.cursor]; ok {
		delete(m.selected, m.cursor)
	} else {
		m.selected[m.cursor] = struct{}{}
	}

	key := m.keys[m.cursor]
	if m.Page.Commands[key] {
		m.inputActive = true
		m.ti.Focus()
		return true
	}
	return false
}

func (m *PageModel) SelectedCommands() []string {
	out := make([]string, 0, len(m.selected))
	for idx := range m.selected {
		out = append(out, m.keys[idx])
	}
	sort.Strings(out)
	return out
}

func (m *PageModel) View() string {
	var s strings.Builder

	s.WriteString(m.Page.Title)
	s.WriteString("\n")
	if m.Page.IsMultiChoice {
		s.WriteString("Pick more than one")
	} else {
		s.WriteString("Pick one")
	}
	s.WriteString("\n")

	for i, key := range m.keys {
		takesInput := m.Page.Commands[key]

		cursor := " "
		if m.cursor == i {
			cursor = ">"
		}

		checked := " "
		if _, ok := m.selected[i]; ok {
			checked = "x"
		}

		inputMarker := ""
		if takesInput {
			inputMarker = " (needs input)"
		}

		fmt.Fprintf(&s, "%s [%s] %s%s\n", cursor, checked, key, inputMarker)
	}

	return s.String()
}

func (m *PageModel) UpdateInput(msg tea.Msg) tea.Cmd {
	var cmd tea.Cmd
	m.ti, cmd = m.ti.Update(msg)
	return cmd
}
